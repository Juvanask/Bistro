{
  "expo": {
    "name": "Bistro",
    "slug": "bistro",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "bistro",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#f4efe6"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bistro.app"
    },
    "android": {
      "package": "com.bistro.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router", "expo-font"],
    "experiments": {
      "typedRoutes": false
    }
  }
}
